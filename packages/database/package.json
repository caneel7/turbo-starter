  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@turbo-starter/typescript-config": "0.0.1",
    "@types/node": "^25.6.0",
    "prisma": "latest",
