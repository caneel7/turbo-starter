{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "lib": ["ESNext"],
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": ["src/**/*.ts"]
}
